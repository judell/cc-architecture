<Component name="FrontendNode">
  <ModalDialog id="frontendDetailDialog" title="XMLUI Frontend">
    <VStack gap="$space-2">
      <Text fontSize="$fontSize-small" color="$textColor-secondary">
        Declarative XMLUI app hosted on GitHub Pages. Queries deduplicated_events via Supabase REST API.
      </Text>
      <Text fontSize="$fontSize-small">
        Features: client-side search with scoring, category filtering, pagination, personal picks (saved to Supabase with RLS), event capture from poster images or audio via Claude/Whisper, list/grid/grouped layouts.
      </Text>
      <Text fontSize="$fontSize-small">
        Auth: GitHub OAuth via Supabase. Admin gating via UUID allowlist table.
      </Text>
    </VStack>
  </ModalDialog>
  <VStack gap="$space-1" padding="$space-2">
    <HStack verticalAlignment="center" horizontalAlignment="center" gap="$space-2">
      <Text fontWeight="bold" fontSize="$fontSize-md">XMLUI Frontend</Text>
      <Text
        fontSize="$fontSize-small"
        color="$color-primary"
        cursor="pointer"
        onClick="frontendDetailDialog.open()">
        ⓘ
      </Text>
    </HStack>
    <Text fontSize="$fontSize-small" color="$textColor-secondary" textAlign="center">
      GitHub Pages, Declarative UI
    </Text>
    <VStack when="{phase &lt; 7}" gap="$space-1">
      <Text fontSize="$fontSize-small" color="$textColor-secondary" textAlign="center">
        Waiting for data...
      </Text>
    </VStack>
    <VStack when="{phase >= 7}" gap="$space-2">
      <VStack
        gap="$space-1"
        padding="$space-2"
        borderRadius="$borderRadius"
        backgroundColor="$color-surface-100">
        <Text fontSize="$fontSize-small" fontWeight="bold">
          Summer Concert Series
        </Text>
        <Text fontSize="$fontSize-small" color="$textColor-secondary">
          Jul 15, Music, 2 sources
        </Text>
      </VStack>
      <VStack
        gap="$space-1"
        padding="$space-2"
        borderRadius="$borderRadius"
        backgroundColor="$color-surface-100">
        <Text fontSize="$fontSize-small" fontWeight="bold">
          Farmers Market
        </Text>
        <Text fontSize="$fontSize-small" color="$textColor-secondary">
          Jul 12, Community, 2 sources
        </Text>
      </VStack>
      <VStack
        gap="$space-1"
        padding="$space-2"
        borderRadius="$borderRadius"
        backgroundColor="$color-surface-100">
        <Text fontSize="$fontSize-small" fontWeight="bold">
          Art Walk
        </Text>
        <Text fontSize="$fontSize-small" color="$textColor-secondary">
          Jul 18, Arts, 1 source
        </Text>
      </VStack>
    </VStack>
  </VStack>
</Component>
