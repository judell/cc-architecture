<Component name="ClassifierNode">
  <ModalDialog id="classifierDetailDialog" title="Claude AI Classifier">
    <VStack gap="$space-2">
      <Text fontSize="$fontSize-small" color="$textColor-secondary">
        Uses Claude Haiku to categorize uncategorized events into standard buckets. Only classifies events that don't already have categories (carried forward from prior builds).
      </Text>
      <Text fontSize="$fontSize-small" fontWeight="bold">
        Categories
      </Text>
      <Text fontSize="$fontSize-small">
        Music, Arts, Sports, Community, Government, Nightlife, Education, Food, Health, Family, and more.
      </Text>
    </VStack>
  </ModalDialog>
  <VStack gap="$space-1" padding="$space-2">
    <HStack verticalAlignment="center" horizontalAlignment="center" gap="$space-2">
      <Text fontWeight="bold" fontSize="$fontSize-md">Claude AI</Text>
      <Text
        fontSize="$fontSize-small"
        color="$color-primary"
        cursor="pointer"
        onClick="classifierDetailDialog.open()">
        ⓘ
      </Text>
    </HStack>
    <Text fontSize="$fontSize-small" color="$textColor-secondary" textAlign="center">
      Classify events (Haiku)
    </Text>
    <Text
      fontSize="$fontSize-small"
      when="{diagramPhase($diagram, phase) &lt; 3}"
      color="$textColor-secondary"
      textAlign="center">
      Waiting for input...
    </Text>
    <Table
      data="{diagramPhase($diagram, phase) >= 4 ? sampleClassified : []}"
      fontSize="$fontSize-small"
      when="{diagramPhase($diagram, phase) >= 4}"
      noDataTemplate="">
      <Column bindTo="title" header="Event" width="2*" />
      <Column bindTo="category" header="Category" />
    </Table>
  </VStack>
</Component>
