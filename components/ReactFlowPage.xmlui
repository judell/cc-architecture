<Component name="ReactFlowPage" var.edgeLabel="" var.edgeId="">

  <ModalDialog id="edgeInfoDialog" title="{edgeLabel}">
    <VStack gap="$space-2">
      <Text>
        {edgeLabel}
      </Text>
      <Text fontSize="$fontSize-small" color="$textColor-secondary">
        Edge ID: {edgeId}
      </Text>
    </VStack>
  </ModalDialog>

  <ModalDialog id="feedsDetailDialog" title="ICS Feed Sources">
    <VStack gap="$space-2">
      <Text fontSize="$fontSize-small" color="$textColor-secondary">
        Native iCalendar feeds from venues and organizations. The preferred source type — structured, reliable, and maintained by event producers.
      </Text>
      <Text fontSize="$fontSize-small">
        47 active feeds across 9 cities. Each feed is an HTTP URL returning .ics data that the pipeline downloads daily.
      </Text>
    </VStack>
  </ModalDialog>

  <ModalDialog id="scrapersDetailDialog" title="Web Scrapers">
    <VStack gap="$space-2">
      <Text fontSize="$fontSize-small" color="$textColor-secondary">
        Python scripts that extract events from websites without ICS feeds. Built on reusable base classes for common platforms.
      </Text>
      <Text fontSize="$fontSize-small">
        120+ site-specific scrapers. Reusable adapters for Eventbrite, Squarespace, Ticketmaster, Legistar (government), BookManager, and more. Each outputs standard .ics with X-SOURCE headers.
      </Text>
    </VStack>
  </ModalDialog>

  <ModalDialog id="curatorDetailDialog" title="Curator Picks">
    <VStack gap="$space-2">
      <Text fontSize="$fontSize-small" color="$textColor-secondary">
        User-contributed personal event picks. Curators add events they know about that aren't covered by feeds or scrapers.
      </Text>
      <Text fontSize="$fontSize-small">
        Submitted via the my-picks edge function. Curators can add rrule (recurrence) and category overrides via event_enrichments.
      </Text>
    </VStack>
  </ModalDialog>

  <ModalDialog id="combineDetailDialog" title="combine_ics.py">
    <VStack gap="$space-2">
      <Text fontSize="$fontSize-small" color="$textColor-secondary">
        Merges all .ics files per city, applies geo-filtering, and runs two rounds of deduplication.
      </Text>
      <Text fontSize="$fontSize-small" fontWeight="bold">
        Cross-source dedup
      </Text>
      <Text fontSize="$fontSize-small">
        Identical title + date from different sources → merge. X-SOURCE headers concatenated.
      </Text>
      <Text fontSize="$fontSize-small" fontWeight="bold">
        Fuzzy dedup
      </Text>
      <Text fontSize="$fontSize-small">
        Token-set string similarity (threshold 0.85). Union-find algorithm assigns cluster IDs. Different locations never clustered.
      </Text>
    </VStack>
  </ModalDialog>

  <ModalDialog id="jsonDetailDialog" title="ics_to_json.py">
    <VStack gap="$space-2">
      <Text fontSize="$fontSize-small" color="$textColor-secondary">
        Parses combined.ics with proper timezone handling (per city.conf), runs fuzzy title clustering, and carries forward categories from previous builds.
      </Text>
      <Text fontSize="$fontSize-small">
        Output: events.json with 1000-5000 events per city. Each event has title, start/end times, location, description, source attribution, and cluster_id.
      </Text>
    </VStack>
  </ModalDialog>

  <ModalDialog id="classifierDetailDialog" title="Claude AI Classifier">
    <VStack gap="$space-2">
      <Text fontSize="$fontSize-small" color="$textColor-secondary">
        Uses Claude Haiku to categorize uncategorized events into standard buckets. Only classifies events that don't already have categories (carried forward from prior builds).
      </Text>
      <Text fontSize="$fontSize-small" fontWeight="bold">
        Categories
      </Text>
      <Text fontSize="$fontSize-small">
        Music &amp; Concerts, Arts &amp; Culture, Sports &amp; Recreation, Community, Government, Nightlife, Education, Food &amp; Drink, Health &amp; Wellness, Family, and more.
      </Text>
    </VStack>
  </ModalDialog>

  <ModalDialog id="loadDetailDialog" title="load-events Edge Function">
    <VStack gap="$space-2">
      <Text fontSize="$fontSize-small" color="$textColor-secondary">
        Deno/TypeScript function deployed to Supabase. Receives {city, events[]} and upserts into the events table.
      </Text>
      <Text fontSize="$fontSize-small">
        Dedup by UNIQUE(source, source_uid). Deletes events no longer in the feed. Returns {success, inserted, deleted}.
      </Text>
    </VStack>
  </ModalDialog>

  <ModalDialog id="supabaseDetailDialog" title="Supabase (PostgreSQL)">
    <VStack gap="$space-2">
      <Text fontSize="$fontSize-small" fontWeight="bold">
        events table
      </Text>
      <Text fontSize="$fontSize-small">
        Raw event records — one per source. Columns: title, start_time, end_time, location, description, url, city, source, category, image_url, all_day.
      </Text>
      <Text fontSize="$fontSize-small" fontWeight="bold">
        deduplicated_events (materialized view)
      </Text>
      <Text fontSize="$fontSize-small">
        Groups by city + normalized_title + start_time. Aggregates source list, merges IDs. The frontend queries this view, not the raw table.
      </Text>
      <Text fontSize="$fontSize-small" fontWeight="bold">
        Row Level Security
      </Text>
      <Text fontSize="$fontSize-small">
        events: public SELECT. picks: authenticated users own rows only. feeds: admin write, public read.
      </Text>
    </VStack>
  </ModalDialog>

  <ModalDialog id="frontendDetailDialog" title="XMLUI Frontend">
    <VStack gap="$space-2">
      <Text fontSize="$fontSize-small" color="$textColor-secondary">
        Declarative XMLUI app hosted on GitHub Pages. Queries deduplicated_events via Supabase REST API.
      </Text>
      <Text fontSize="$fontSize-small">
        Features: client-side search with scoring, category filtering, pagination, personal picks (saved to Supabase with RLS), event capture from poster images or audio via Claude/Whisper, list/grid/grouped layouts.
      </Text>
      <Text fontSize="$fontSize-small">
        Auth: GitHub OAuth via Supabase. Admin gating via UUID allowlist table.
      </Text>
    </VStack>
  </ModalDialog>

  <DataSource
    id="layoutData"
    url="layout.json"
    onLoaded="{(data) => { layout = data }}" />

  <!-- Phase transition timers -->

  <Timer
    enabled="{phase === 'collecting'}"
    interval="{pulseDuration}"
    onTick="{() => onCollectDone()}" />

  <Timer
    enabled="{phase === 'combining'}"
    interval="{pulseDuration}"
    onTick="{() => onCombineDone()}" />

  <Timer
    enabled="{phase === 'converting'}"
    interval="{pulseDuration}"
    onTick="{() => onConvertDone()}" />

  <Timer
    enabled="{phase === 'classifying'}"
    interval="{pulseDuration}"
    onTick="{() => onClassifyDone()}" />

  <Timer
    enabled="{phase === 'loading'}"
    interval="{pulseDuration}"
    onTick="{() => onLoadDone()}" />

  <Timer
    enabled="{phase === 'refreshing'}"
    interval="{pulseDuration}"
    onTick="{() => onRefreshDone()}" />

  <Timer
    enabled="{roundTrip !== ''}"
    interval="{pulseDuration * 2}"
    onTick="{() => onRoundTripComplete()}" />

  <Timer
    enabled="{phase === 'displaying'}"
    interval="{pulseDuration}"
    onTick="{() => onDisplayDone()}" />

  <Stack
    height="calc(100vh - 48px)"
    width="100%"
    when="{layout !== null}"
    position="relative">
    <ReactFlowCanvas
      id="canvas"
      canvasFontSize="{16}"
      fitView="{true}"
      fitViewPadding="{.12}"
      snapToGrid="{true}"
      showMinimap="{false}"
      showControls="{true}"
      showBackground="{true}"
      onEdgeInfoClick="{(e) => { edgeLabel = e.label; edgeId = e.edgeId; edgeInfoDialog.open() }}"
      nodes="{(phase, phaseLabel, phaseMessage, buttonLabel, buttonEnabled, getNodes())}"
      edges="{getEdges()}">
      <IcsFeedsNode />
      <ScrapersNode />
      <CuratorNode />
      <GitHubActionsNode />
      <CombineNode />
      <IcsToJsonNode />
      <ClassifierNode />
      <LoadEventsNode />
      <SupabaseNode />
      <FrontendNode />
      <HStack>
        <H1>
          {phaseLabel} {phaseMessage}
        </H1>
        <ControlNode />
      </HStack>
    </ReactFlowCanvas>
  </Stack>
</Component>
