<Component name="PersonAgentNode">
  <ModalDialog id="paHelp" title="Alice's Agent">
    <Text>
      A software agent that acts on behalf of the person to negotiate and record agreements.
    </Text>
  </ModalDialog>
  <VStack gap="$space-1" padding="$space-2">
    <HStack verticalAlignment="center" horizontalAlignment="center" gap="$space-2">
      <Icon name="bot" width="24px" height="24px" />
      <Text fontWeight="bold" fontSize="$fontSize-lg">Alice's Agent</Text>
    </HStack>
    <Text
      fontSize="$fontSize-small"
      color="$textColor-secondary"
      when="{phase < 4}">
      Waiting for term...
    </Text>
    <Text
      fontSize="$fontSize-small"
      fontWeight="bold"
      color="$color-primary"
      when="{phase >= 3 && offeredTerm !== ''}">
      Received: {offeredTerm}
    </Text>
  </VStack>
</Component>